# ── Vertex AI / Google Cloud ────────────────────────────────────────────────
GOOGLE_GENAI_USE_VERTEXAI="true"
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="global"

# ── Google Maps Places API ──────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Places API (New)
GOOGLE_MAPS_API_KEY=""

# ── Google Calendar API ─────────────────────────────────────────────────────
# OAuth2 access token for the signed-in user.
# On Cloud Run: auto-fetched from GCE metadata server (Workload Identity)
# For local dev: run `gcloud auth print-access-token` after enabling Calendar API
GOOGLE_CALENDAR_TOKEN=""
GOOGLE_CALENDAR_ID="primary"

# ── AlloyDB / Cloud SQL (Accountant Agent) ──────────────────────────────────
DB_HOST="127.0.0.1"
DB_USER="postgres"
DB_PASS="YOUR_DB_PASSWORD_HERE"
DB_NAME="expenses_db"

# ── Sub-agent card URLs (when deployed) ────────────────────────────────────
LOGISTICS_AGENT_CARD_URL=""
TRAVEL_RESEARCHER_AGENT_CARD_URL=""
POLICY_AUDITOR_AGENT_CARD_URL=""
ACCOUNTANT_AGENT_CARD_URL=""

# ── Frontend ────────────────────────────────────────────────────────────────
AGENT_SERVER_URL="http://localhost:8000"
